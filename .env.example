# Copy this file to `.env` in the project root and fill in what you need.
# Nothing here is required for the core forecast/chat flow to work --
# these only unlock optional extras.

# --- Kronos model (optional overrides) ---
KRONOS_MODEL_ID=NeoQuasar/Kronos-small
KRONOS_TOKENIZER_ID=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MAX_CONTEXT=512
DEFAULT_LOOKBACK_DAYS=400
DEFAULT_PRED_LEN=30
KRONOS_TEMPERATURE=0.7
DEFAULT_KRONOS_SAMPLE_COUNT=5
DEFAULT_SAMPLE_RUNS=1
# Limit PyTorch CPU threads when running without a GPU (e.g. AMD Radeon
# iGPU). Leave blank for torch's default (usually all cores). A good
# starting point on a 6-core/12-thread laptop CPU with 8GB RAM is 4-6.
KRONOS_CPU_THREADS=

# --- Quick in-chat backtest ("backtest AAPL") ---
BACKTEST_QUICK_HORIZONS=5,14,30
BACKTEST_QUICK_MAX_WINDOWS=15
BACKTEST_QUICK_MIN_TRAIN_SIZE=252
BACKTEST_QUICK_STEP_SIZE=30

# --- Optional news sources (yfinance news works with none of these set) ---
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
NEWSAPI_API_KEY=

# --- Optional: smarter NL understanding / explanation wording ---
ANTHROPIC_API_KEY=

# --- Discord bot (integrations/discord_bot.py) ---
DISCORD_BOT_TOKEN=

# --- WhatsApp bot via Twilio (integrations/whatsapp_bot.py) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_BASE_URL=
